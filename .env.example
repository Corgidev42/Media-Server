# ========================================
# 🔐 VARIABLES D'ENVIRONNEMENT
# ========================================
# COPIEZ ce fichier en .env et remplissez vos vraies valeurs
# Commande: cp .env.example .env

# ========================================
# 👤 UTILISATEUR (PUID/PGID)
# ========================================
# Pour trouver vos valeurs: id -u (PUID) et id -g (PGID)

PUID=503
PGID=20

# ========================================
# 🕐 TIMEZONE
# ========================================
TZ=Europe/Paris

# ========================================
# 📁 STOCKAGE
# ========================================
# Chemin racine pour les téléchargements et médias
DATA_PATH=/Users/dev/data

# ========================================
# 🌐 VPN NORDVPN (Service Credentials)
# ========================================
# ⚠️ NE PAS utiliser votre email/password NordVPN !
# ✅ Dashboard → Services → NordVPN → Manual Setup

NORDVPN_SERVICE_USER=
NORDVPN_SERVICE_PASSWORD=

# ========================================
# 🔐 COMPTE ADMIN (tous les services)
# ========================================
# Utilisé pour Jellyfin, Radarr, Sonarr, Prowlarr
ADMIN_USER=admin
ADMIN_PASSWORD=

# ========================================
# 🎬 JELLYFIN
# ========================================
# URL locale pour le setup CLI
JELLYFIN_HOST=http://localhost:8096
# URL publiée pour les clients (Infuse, Jellyseerr, etc.)
JELLYFIN_URL=http://192.168.1.17:8096
JELLYFIN_SERVER_NAME="Media Server"
JELLYFIN_LANG=fr
JELLYFIN_COUNTRY=FR

# ========================================
# 📊 JELLYSTAT (PostgreSQL)
# ========================================
JELLYSTAT_DB_PASSWORD=jellystat
JELLYSTAT_JWT_SECRET=change-me-to-a-random-secret

# ========================================
# 🔑 API KEYS (*arr) — générées automatiquement par setup.sh
# ========================================
# Laissez vide pour auto-génération, ou collez vos clés existantes
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=

# ========================================
# 🔧 RECYCLARR (URLs internes Docker)
# ========================================
RADARR_URL=http://radarr:7878
SONARR_URL=http://sonarr:8989

# ========================================
# 📦 QBITTORRENT
# ========================================
QBITTORRENT_PASSWORD=

# ========================================
# � JACKETT (YGGTorrent)
# ========================================
# Généré automatiquement par setup.sh
JACKETT_API_KEY=

# ========================================
# 💎 ALLDEBRID (via RDTClient)
# ========================================
# Clé API depuis https://alldebrid.fr/apikeys/
# Configurer dans RDTClient UI : http://localhost:6500
ALLDEBRID_API_KEY=

# ========================================
# �🛡️ FLARESOLVERR (optionnel)
# ========================================
LOG_LEVEL=info
LOG_HTML=false
CAPTCHA_SOLVER=none
